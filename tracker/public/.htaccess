<IfModule mod_rewrite.c>
  DirectoryIndex index.html
  RewriteEngine On
  RewriteBase /uber/
  
  # Don't rewrite API requests (adjust if your API path is different)
  RewriteCond %{REQUEST_URI} ^/Initeck-api [NC]
  RewriteRule ^ - [L]

  # Don't rewrite files or directories
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Rewrite everything else to /uber/index.html for React Router
  RewriteRule ^ /uber/index.html [L]
</IfModule>

